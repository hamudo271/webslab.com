# === Site ===
NEXT_PUBLIC_SITE_URL=https://webslab.co.kr

# === Contact backend (Resend) ===
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxx_replace_me
CONTACT_FROM_EMAIL=hello@webslab.co.kr
CONTACT_TO_EMAIL=contact@webslab.co.kr

# Set CONTACT_DRY_RUN=true in dev to log payload instead of sending email
CONTACT_DRY_RUN=true

# === Analytics (placeholders — loaders no-op until real IDs are set) ===
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_NAVER_ANALYTICS_ID=xxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx
NEXT_PUBLIC_HOTJAR_ID=0000000
NEXT_PUBLIC_CHANNEL_IO_KEY=replace_me
NEXT_PUBLIC_MIXPANEL_TOKEN=replace_me

# === Site verification (search consoles) ===
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=replace_me
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=replace_me
